# Root .env.example — kopieer naar .env en vul in

# Supabase (zowel lokaal als remote)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Next.js public vars (prefix NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Data-APIs: allemaal open, geen keys nodig
# PDOK BAG OGC API, PDOK Locatieserver, EP-Online, KOOP SRU → gratis zonder registratie

# Mollie (betalingen)
MOLLIE_API_KEY=test_xxxx
MOLLIE_WEBHOOK_SECRET=your-webhook-secret

# Resend (email)
RESEND_API_KEY=re_xxxx

# Sentry (error tracking)
SENTRY_DSN=https://xxxx@sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Debug
DEBUG=true
